{
  "name": "doaime-desktop",
  "version": "1.0.2",
  "description": "DoAi.Me desktop agent controller",
  "author": "doaime",
  "private": true,
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.electron.json && concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "test": "node src/agent/scripts/smoke-require-agent.js",
    "agent:run": "node src/agent/agent.js",
    "bundle:agent": "node src/scripts/bundle-agent.js",
    "prepare:packaged-env": "node src/scripts/prepare-packaged-env.js",
    "dist:clean": "node -e \"require('fs').rmSync('release', { recursive: true, force: true })\"",
    "version:patch": "node -e \"const p=require('./package.json');const [a,b,c]=p.version.split('.').map(Number);require('fs').writeFileSync('package.json', JSON.stringify({...p,version:[a,b,c+1].join('.')}, null, 2)); console.log('Bumped to', [a,b,c+1].join('.'));\"",
    "dist:win": "pnpm run bundle:agent && pnpm run prepare:packaged-env && electron-builder --win",
    "dist": "pnpm run test && pnpm run build && node src/scripts/download-node-win.js && pnpm run dist:win",
    "dist:wsl": "pnpm run test && pnpm run build && node src/scripts/download-node-win.js && pnpm run bundle:agent && pnpm run prepare:packaged-env && WINEPREFIX=$HOME/.wine-eb WINEARCH=win32 electron-builder --win",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json",
    "lint": "eslint src/renderer --ext .ts,.tsx"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.3.0",
    "@mui/material": "^6.3.0",
    "@supabase/supabase-js": "^2.47.10",
    "archiver": "^7.0.1",
    "cron-parser": "^4.9.0",
    "dotenv": "^16.4.5",
    "electron-log": "^5.2.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "winston": "^3.17.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-react": "^4.3.4",
    "adm-zip": "^0.5.16",
    "concurrently": "^9.1.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "electron-builder-squirrel-windows": "^26.8.1",
    "esbuild": "^0.24.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.14.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "me.doai.desktop",
    "productName": "doaime",
    "forceCodeSigning": false,
    "mac": null,
    "linux": null,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**"
    ],
    "extraResources": [
      {
        "from": "agent-dist",
        "to": "agent"
      },
      {
        "from": "node-bundle",
        "to": "node"
      },
      {
        "from": "release.env",
        "to": ".env"
      },
      {
        "from": "release.env",
        "to": "agent/.env"
      }
    ],
    "win": {
      "target": "nsis",
      "executableName": "doaime",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh"
    },
    "npmRebuild": false
  }
}
