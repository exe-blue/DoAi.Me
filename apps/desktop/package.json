{
  "name": "@doai/desktop",
  "version": "1.0.1",
  "description": "DoAi.Me desktop agent controller",
  "author": "doaime",
  "private": true,
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.electron.json && concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "pnpm exec tsc -p tsconfig.electron.json && pnpm exec vite build",
    "test": "node ../../packages/agent/scripts/smoke-require-agent.js",
    "dist": "pnpm install && node scripts/bump-version.js && pnpm run test && pnpm run build && node scripts/download-node-win.js && pnpm --filter @doai/agent install --prod && pnpm install --filter @doai/desktop && node scripts/copy-env-to-agent.js && pnpm exec electron-builder --win",
    "dist:publish": "pnpm install && node scripts/bump-version.js && pnpm run test && pnpm run build && node scripts/download-node-win.js && pnpm --filter @doai/agent install --prod && pnpm install --filter @doai/desktop && node scripts/copy-env-to-agent.js && pnpm exec electron-builder --win --publish always",
    "dist:wsl": "pnpm run test && pnpm run build && node scripts/download-node-win.js && pnpm --filter @doai/agent install --prod && WINEPREFIX=$HOME/.wine-eb WINEARCH=win32 pnpm exec electron-builder --win",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json",
    "lint": "eslint src/renderer --ext .ts,.tsx"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.3.0",
    "@mui/material": "^6.3.0",
    "@supabase/supabase-js": "^2.47.10",
    "archiver": "^7.0.1",
    "cron-parser": "^5.5.0",
    "dotenv": "^16.4.5",
    "electron-log": "^5.2.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "winston": "^3.17.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@doai/typescript-config": "workspace:*",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-react": "^4.3.4",
    "adm-zip": "^0.5.16",
    "concurrently": "^9.1.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "electron-builder-squirrel-windows": "^26.8.1",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.14.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "me.doai.desktop",
    "productName": "doaime",
    "publish": {
      "provider": "github",
      "owner": "doai-me",
      "repo": "doai.me"
    },
    "mac": null,
    "linux": null,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**"
    ],
    "extraResources": [
      {
        "from": "../../packages/agent",
        "to": "agent",
        "filter": [
          "**/*",
          "!.env.*",
          "!.env.example"
        ]
      },
      {
        "from": "node-bundle",
        "to": "node"
      },
      {
        "from": ".env.prod",
        "to": ".env"
      }
    ],
    "win": {
      "target": "nsis",
      "executableName": "doaime",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh"
    },
    "npmRebuild": false
  }
}
