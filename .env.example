# DoAi.Me - Web Application (Next.js)
# 복사 후 .env.local 로 저장: cp .env.example .env.local

# ── Supabase (필수) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# API Routes 전용 (서버에서만 사용, 클라이언트 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── YouTube Data API (채널 동기화용) ─────────────
YOUTUBE_API_KEY=AIzaSyCFWiq9V7taYn37Qwlr7Ne-mddy31wwsOA

# ── Supabase Scheduled Jobs (pg_cron 인증용) ──────
# pg_cron에서 /api/cron/* 엔드포인트 호출 시 사용하는 공유 비밀키
# 이 값은 Supabase Vault의 app_schedule_secret과 동일해야 함
APP_SCHEDULE_SECRET=your-random-secret-string-here

# ── Supabase CLI / MCP (선택) ────────────────────
# Personal Access Token: 대시보드 Account > Access Tokens 에서 발급.
# MCP(쿼리/DB 접근) 또는 supabase CLI 인증에 사용. .env.local 에만 설정 권장.
# SUPABASE_ACCESS_TOKEN=sbp_...
